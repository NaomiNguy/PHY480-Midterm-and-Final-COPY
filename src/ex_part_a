import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv(
    "TESSA_lc.dat",
    delim_whitespace=True,
    comment="#",
    names=["time", "flux", "flux_err"],
)

t0 = df["time"].iloc[0]
df["t_rel"] = df["time"] - t0

plt.figure(figsize=(8, 4))
plt.scatter(df["t_rel"], df["flux"], s=5)
plt.xlabel("Relative Time (days)")
plt.ylabel("Flux")
plt.title("Raw TESS Light Curve")
plt.show()