median_flux = np.median(df["flux"])
df["flux_norm"] = df["flux"] / median_flux

print("Median after normalization:", np.median(df["flux_norm"]))

plt.figure(figsize=(8,4))
plt.scatter(df["t_rel"], df["flux_norm"], s=5)
plt.axhline(1, linestyle="--", color="red")
plt.xlabel("Relative Time (days)")
plt.ylabel("Normalized Flux")
plt.title("Normalized Light Curve")
plt.show()

t_test = np.linspace(0,10,100)
flux_const = np.ones_like(t_test)

coeff = np.polyfit(t_test, flux_const, 2)
trend = np.polyval(coeff, t_test)

flux_detrended = flux_const / trend

print("Mean detrended constant:", np.mean(flux_detrended))